# Azure App Service production environment template for QuantumShield backend
# Copy values into Azure App Service -> Configuration -> Application settings.

# API and CORS
CORS_ALLOW_ORIGINS=https://quanthunt.netlify.app
ALLOW_INSECURE_CORS=false

# Runtime mode
USE_CELERY=true
REDIS_URL=redis://<your-redis-host>:6379/0

# Recommended scan tuning (balanced throughput and stability)
# Deep scan settings
SCAN_MAX_ASSETS_DEEP=120
SCAN_CONCURRENCY_DEEP=16

# Shallow scan settings
SCAN_MAX_ASSETS_SHALLOW=40
SCAN_CONCURRENCY_SHALLOW=10

# Timeouts and progress logging
SCAN_ASSET_TIMEOUT_SEC=10.0
SCAN_AI_TIMEOUT_SEC=2.2
SCAN_PROGRESS_LOG_EVERY=10
SCAN_EXTERNAL_AI_BUDGET=20

# VPN checks
VPN_BLOCK_ENABLED=true
VPN_BLOCK_ON_PROXY=true
VPN_BLOCK_ON_HOSTING=true
VPN_CHECK_TIMEOUT_SEC=2.5
VPN_CACHE_TTL_SEC=300
VPN_TRUST_X_FORWARDED_FOR=true
VPN_SCORE_THRESHOLD=70

# Optional behavior
REUSE_COMPLETED_SCANS=true
