{
  "rewrites": [
    {
      "source": "/app.jsx",
      "destination": "https://quanthunt-production-5687.up.railway.app/app.jsx"
    },
    {
      "source": "/config.js",
      "destination": "https://quanthunt-production-5687.up.railway.app/config.js"
    },
    {
      "source": "/styles.css",
      "destination": "https://quanthunt-production-5687.up.railway.app/styles.css"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://quanthunt-production-5687.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "https://quanthunt-production-5687.up.railway.app/$1"
    }
  ]
}
