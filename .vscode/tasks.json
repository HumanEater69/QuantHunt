{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start backend (Python)",
			"type": "shell",
			"command": ".venv\\Scripts\\python.exe -m uvicorn backend.main:app --host 127.0.0.1 --port 8000",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Start frontend (React/Vite/JSX)",
			"type": "shell",
			"command": "npx serve frontend --single --listen 3000",
			"isBackground": true,
			"group": "build"
		}
	]
}