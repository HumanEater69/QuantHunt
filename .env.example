# Vercel frontend
# Set in frontend/config.js or replace the rewrite destination in frontend/vercel.json.
QUANTHUNT_RENDER_URL=https://YOUR-RENDER-SERVICE.onrender.com

# Render API -> Supabase Postgres
# Use Supabase Project Settings -> Database -> Connection string.
# Prefer the transaction pooler URI for hosted/serverless deployments.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?sslmode=require
BANKING_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Render API CORS
CORS_ALLOW_ORIGINS=https://YOUR-VERCEL-APP.vercel.app,http://localhost:5177,http://127.0.0.1:5177

# Optional Supabase table-queue worker
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
QUANTHUNT_WORKER_POLL_SECONDS=8
